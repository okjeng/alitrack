# ════════════════════════════════════════════════════════
# AliTrack .env 템플릿
# 이 파일을 복사해서 .env 로 저장 후 실제 값을 채우세요
# ⚠️  .env 파일은 절대 Git에 커밋하지 마세요!
# ⚠️  .gitignore 에 반드시 .env 추가 확인!
# ════════════════════════════════════════════════════════

# ── 서버 환경 ────────────────────────────────────────────
ENV=production
DEBUG=false
ALLOWED_HOSTS=alitrack-production.up.railway.app,alitrack.pages.dev
ALLOWED_ORIGINS=https://alitrack.pages.dev,https://alitrack-production.up.railway.app
# DNS 설정 완료 후:
# ALLOWED_HOSTS=alitrack.kr,www.alitrack.kr,api.alitrack.kr
# ALLOWED_ORIGINS=https://alitrack.kr,https://www.alitrack.kr

# ── 프론트엔드 URL ────────────────────────────────────────
FRONTEND_URL=https://alitrack.pages.dev
# DNS 완료 후: FRONTEND_URL=https://alitrack.kr

# ── 알리익스프레스 제휴 API ──────────────────────────────
ALI_APP_KEY=여기에_앱키_입력
ALI_APP_SECRET=여기에_시크릿_입력
ALI_TRACKING_ID=여기에_트래킹ID_입력

# ── 데이터베이스 (Supabase PostgreSQL) ───────────────────
DATABASE_URL=postgresql+asyncpg://postgres:[비밀번호]@db.[프로젝트ID].supabase.co:5432/postgres

# ── JWT 서명 키 ──────────────────────────────────────────
# 생성 명령: openssl rand -hex 32
JWT_SECRET=여기에_32자_이상_랜덤_문자열_입력
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── 이메일 알림 (Gmail) ──────────────────────────────────
# Gmail 앱 비밀번호: Google 계정 → 보안 → 앱 비밀번호
GMAIL_ADDRESS=turtlesmotivation@gmail.com
GMAIL_APP_PASSWORD=여기에_앱비밀번호_입력_(계정비번_아님)

# ── 스케줄러 인증 키 ─────────────────────────────────────
CRON_SECRET=여기에_랜덤_시크릿_입력

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Supabase ─────────────────────────────────────────────
SUPABASE_URL=https://[프로젝트ID].supabase.co
SUPABASE_KEY=여기에_service_role_key_입력
