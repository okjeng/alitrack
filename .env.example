# AliTrack 환경변수 예시
# 이 파일을 복사해 .env 로 저장하고 값을 채우세요

# ── Google Analytics 4 ─────────────────────────────────────────
# GA4 측정 ID: Google Analytics → 관리 → 데이터 스트림에서 발급
# G-XXXXXXXXXX 형식. 비워두면 GA4 비활성화
VITE_GA4_ID=

# ── API 서버 ────────────────────────────────────────────────────
# 기본값: https://alitrack-production.up.railway.app
VITE_API_BASE_URL=

# ── Channel.io 고객 채팅 ────────────────────────────────────────
# Channel Talk → 설정 → 채널 플러그인 키
VITE_CHANNEL_PLUGIN_KEY=
