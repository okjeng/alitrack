# ════════════════════════════════════════════════════════════════════
# AliTrack 환경변수 전체 목록
# ⚠️  이 파일은 예시용 템플릿입니다. 실제 값을 절대 여기에 쓰지 마세요.
# ⚠️  실제 .env / .env.production 파일은 .gitignore에 의해 Git 제외됩니다.
# ════════════════════════════════════════════════════════════════════

# ── [프론트엔드] Cloudflare Pages 환경변수 ─────────────────────────
# Cloudflare Pages > 프로젝트 > Settings > Environment variables 에 추가
VITE_API_BASE_URL=https://alitrack-production.up.railway.app
# DNS 완료 후: VITE_API_BASE_URL=https://api.alitrack.kr

# ── [백엔드] Railway 환경변수 ─────────────────────────────────────
# Railway 대시보드 > 프로젝트 > Variables 에 추가

# 서버 환경
ENV=production
DEBUG=false

# CORS / 호스트 화이트리스트
# DNS 완료 후: alitrack.kr,www.alitrack.kr,api.alitrack.kr
ALLOWED_HOSTS=alitrack-production.up.railway.app,alitrack.pages.dev
ALLOWED_ORIGINS=https://alitrack.pages.dev,https://alitrack-production.up.railway.app

# JWT 서명 키 — 최소 32자 랜덤 문자열 필수
# 생성 방법: openssl rand -hex 32
JWT_SECRET=최소32자이상_랜덤_문자열_여기에_입력
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Supabase (DB)
# Supabase 대시보드 > Settings > API 에서 확인
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-service-role-key   # service_role key (anon key 아님)

# 알리익스프레스 제휴 API
# https://portals.aliexpress.com 에서 발급
ALI_APP_KEY=your-ali-app-key
ALI_APP_SECRET=your-ali-app-secret
ALI_TRACKING_ID=your-tracking-id

# 소셜 로그인 공통
FRONTEND_URL=https://alitrack.pages.dev
# DNS 완료 후: FRONTEND_URL=https://alitrack.kr

# 카카오 로그인
# https://developers.kakao.com > 내 앱 > 앱 키 / 보안
KAKAO_CLIENT_ID=your-kakao-app-key
KAKAO_CLIENT_SECRET=your-kakao-client-secret   # 보안 탭에서 활성화 필요
KAKAO_REDIRECT_URI=https://alitrack-production.up.railway.app/api/auth/kakao/callback
# DNS 완료 후: KAKAO_REDIRECT_URI=https://api.alitrack.kr/api/auth/kakao/callback

# 네이버 로그인
# https://developers.naver.com > Application > 등록
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret
NAVER_REDIRECT_URI=https://alitrack-production.up.railway.app/api/auth/naver/callback
# DNS 완료 후: NAVER_REDIRECT_URI=https://api.alitrack.kr/api/auth/naver/callback

# 구글 로그인
# https://console.cloud.google.com > OAuth 2.0 클라이언트 ID
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://alitrack-production.up.railway.app/api/auth/google/callback
# DNS 완료 후: GOOGLE_REDIRECT_URI=https://api.alitrack.kr/api/auth/google/callback

# Redis (Rate Limiting — Railway Redis 플러그인 추가 시 자동 주입됨)
REDIS_URL=redis://localhost:6379/0

# Gmail (할인코드 자동 파싱 — 미사용 시 공란 가능)
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
